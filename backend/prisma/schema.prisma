generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  BigInt               @id @default(autoincrement())
  email               String               @unique @db.VarChar(255)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  name                String               @db.VarChar(255)
  role                String               @default("user") @db.VarChar(50)
  charityId           BigInt?              @map("charity_id")
  charityPercentage   Int                  @default(10) @map("charity_percentage")
  subscriptionStatus  String               @default("inactive") @map("subscription_status") @db.VarChar(50)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  charity             Charity?             @relation(fields: [charityId], references: [id], onDelete: SetNull)
  subscriptions       Subscription[]
  scores              Score[]
  drawResults         DrawResult[]
  paymentTransactions PaymentTransaction[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([role])
  @@index([charityId])
  @@map("users")
}

model Charity {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?
  category    String?  @db.VarChar(100)
  website     String?  @db.VarChar(255)
  logoUrl     String?  @map("logo_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  users       User[]

  @@map("charities")
}

model Subscription {
  id                   BigInt    @id @default(autoincrement())
  userId               BigInt    @map("user_id")
  planType             String    @map("plan_type") @db.VarChar(50)
  status               String    @default("active") @db.VarChar(50)
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?   @map("stripe_subscription_id") @db.VarChar(255)
  startDate            DateTime  @default(now()) @map("start_date")
  endDate              DateTime? @map("end_date")
  amount               Decimal   @db.Decimal(10, 2)
  createdAt            DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

model Score {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  value      Int
  datePlayed DateTime @map("date_played") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, datePlayed])
  @@index([userId])
  @@map("scores")
}

model Draw {
  id             BigInt      @id @default(autoincrement())
  drawDate       DateTime    @unique @map("draw_date") @db.Date
  winningNumbers Int[]       @map("winning_numbers")
  prizePool      Decimal     @map("prize_pool") @db.Decimal(12, 2)
  jackpotAmount  Decimal     @map("jackpot_amount") @db.Decimal(12, 2)
  status         String      @default("completed") @db.VarChar(50)
  createdAt      DateTime    @default(now()) @map("created_at")

  results        DrawResult[]

  @@map("draws")
}

model DrawResult {
  id           BigInt   @id @default(autoincrement())
  drawId       BigInt   @map("draw_id")
  userId       BigInt   @map("user_id")
  matchedCount Int      @map("matched_count")
  prizeAmount  Decimal  @default(0) @map("prize_amount") @db.Decimal(12, 2)
  verified     Boolean  @default(false)
  proofUrl     String?  @map("proof_url")
  createdAt    DateTime @default(now()) @map("created_at")

  draw Draw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([drawId, userId])
  @@index([drawId])
  @@index([userId])
  @@index([verified])
  @@map("draw_results")
}

model PaymentTransaction {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt?  @map("user_id")
  sessionId     String?  @unique @map("session_id") @db.VarChar(255)
  amount        Decimal? @db.Decimal(10, 2)
  currency      String?  @default("usd") @db.VarChar(10)
  status        String?  @db.VarChar(50)
  paymentStatus String?  @map("payment_status") @db.VarChar(50)
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("payment_transactions")
}

model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  id          BigInt   @id @default(autoincrement())
  identifier  String   @unique @db.VarChar(255)
  attempts    Int      @default(1)
  lockedUntil DateTime? @map("locked_until")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("login_attempts")
}